# Configuración de Odoo
ODOO_URL=https://tu-instancia.odoo.com
ODOO_DB=nombre-de-tu-base-de-datos
ODOO_USER=tu_usuario@example.com
ODOO_PASSWORD=tu_api_key_o_password

# Clave secreta para Flask (genera una con: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=genera_una_clave_secreta_unica_aqui

# Base de datos PostgreSQL para Analytics (opcional)
DATABASE_URL=

# Supabase para Metas de Ventas
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu_clave_publica_supabase

# OAuth2 Google - Obtener desde Google Cloud Console
GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_google_client_secret

# Usuarios permitidos (separados por comas)
ALLOWED_USERS=usuario1@example.com,usuario2@example.com

# Configuración de Flask
FLASK_ENV=development

# Seguridad de sesiones (A01: Broken Authentication)
# Habilitar verificación de expiración de sesión (true/false)
ENABLE_SESSION_EXPIRATION=false

# Timeout de INACTIVIDAD: minutos sin actividad antes de expirar sesión
# Recomendado: 15-30 minutos para producción, más alto para desarrollo
MAX_IDLE_MINUTES=15

# Timeout ABSOLUTO: horas máximas desde login (independiente de actividad)
# Recomendado: 8 horas para aplicaciones normales, menos para sistemas críticos
MAX_ABSOLUTE_SESSION_HOURS=8

# Nivel de logging (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# CORS: Orígenes permitidos para cross-origin requests (A04: Insecure Design)
# Separados por comas. Dejar vacío para bloquear todos los cross-origin requests
# Ejemplo: https://dashboard.ejemplo.com,https://admin.ejemplo.com
CORS_ALLOWED_ORIGINS=
