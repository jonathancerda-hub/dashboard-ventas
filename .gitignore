# Entorno Virtual de Python
# Ignora la carpeta que contiene todas las librerías instaladas.
venv/

# Archivos de caché de Python
# Estos se generan automáticamente y no deben ser versionados.
__pycache__/
*.py[cod]

# Archivos de entorno
# Contiene variables sensibles como la SECRET_KEY y el nombre de la hoja de Google.
.env
.env.local
.env.*.local

# Credenciales
# ¡MUY IMPORTANTE! Nunca subas este archivo a un repositorio público.
credentials.json
*.pem
*.key

# Lista de usuarios autorizados
# Contiene correos electrónicos del personal
allowed_users.json
whitelist.txt
RENDER_SETUP.md

# Reportes de seguridad y datos sensibles
security_reports/
datos_reporte_ceo.json
*.backup
*.bak

# Archivos específicos del editor de código (ej. VSCode)
.vscode/

# Archivos de sistema operativo
.DS_Store

# Archivos de registro (si se generan)
*.log

# Archivos de datos locales (ahora obsoletos, pero es bueno ignorarlos)
metas.json
equipos_ventas.json
metas_vendedores.json
# Bases de datos locales
*.db
*.sqlite
*.sqlite3

# Archivos de test en la raíz (no en tests/)
/test_*.py
/check_*.py
